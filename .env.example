# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# JWT signing algorithm
JWT_ALGORITHM=HS256

# Hugging Face Token (Highly Recommended for faster model downloads and to avoid rate limits)
HF_TOKEN=
